{
  "name": "cowrie-codec",
  "version": "0.1.1",
  "description": "Cowrie - Structured JSON binary codec for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:coverage": "npx c8 --check-coverage --lines 80 --reporter text --reporter text-summary node --import tsx --test src/**/*.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "json",
    "binary",
    "serialization",
    "codec",
    "tensor",
    "ml"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neumenon/cowrie"
  },
  "files": [
    "dist"
  ],
  "optionalDependencies": {
    "fzstd": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "c8": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
